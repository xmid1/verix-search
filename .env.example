# ═══════════════════════════════════════════════════════════════
# Verix Search — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Secrets are managed via Replit Secrets or your deployment's secret store.
# This file documents everything the app reads; do not put real secrets here.
# ═══════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=info

# API version prefix
API_VERSION=v1

# CORS (comma-separated list of origins, or * for all)
CORS_ORIGIN=*

# ─────────────────────────────────────────────────────────────
# 1. REQUIRED — Core Dependencies
# ─────────────────────────────────────────────────────────────

# PostgreSQL with pgvector extension (Supabase, Neon, or any Postgres 17+)
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/verix

# Redis for cache + BullMQ queues (Upstash, Redis Cloud, or self-hosted)
REDIS_URL=redis://user:password@host:6379

# LLM API key (OpenCode Zen — OpenAI-compatible gateway, includes free tier)
# Get one at: https://opencode.ai/zen
OPENCODE_API_KEY=sk-your-opencode-api-key

# ─────────────────────────────────────────────────────────────
# 2. AUTH — JWT + API Keys
# ─────────────────────────────────────────────────────────────

# JWT secret (min 16 chars). In production, this MUST be a strong random value.
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-at-least-16-chars
JWT_EXPIRES_IN=12h

# ─────────────────────────────────────────────────────────────
# 3. SEARCH PROVIDERS — API Keys (Optional but Recommended)
# ─────────────────────────────────────────────────────────────
# These providers work without API keys but with reduced quality/rate limits.
# Setting the key unlocks full access. Leave empty to use public fallback.

# ── Brave Search ─────────────────────────────────────────────
# Without key: DISABLED (Brave requires an API key for all access)
# Free tier: 2,000 queries/month
# Get key: https://brave.com/search/api/
BRAVE_API_KEY=

# ── Reddit ───────────────────────────────────────────────────
# Without key: uses public reddit.com/search.json (blocked on some cloud IPs)
# With key: OAuth2 access, works from any IP, higher rate limits
# Get credentials: https://www.reddit.com/prefs/apps → create "script" app
#   - Client ID: the string under the app name (e.g., "abc123def456")
#   - Client Secret: the "secret" field
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Twitter / X ──────────────────────────────────────────────
# Without key: HTML scraping (brittle, may break with site changes)
# Free tier: 500k tweets/month (Basic API)
# Get key: https://developer.twitter.com/ → create project → generate Bearer Token
TWITTER_BEARER_TOKEN=

# ── Google News ──────────────────────────────────────────────
# Without key: RSS scraping (no search, just recent headlines per source)
# Get key: https://gnews.io/ (free tier: 100 requests/day)
GOOGLE_API_KEY=

# ── Google Custom Search ─────────────────────────────────────
# Optional: enhances search quality for general web results
# Get: https://programmablesearchengine.google.com/ (create search engine, get CX ID + API key)
GOOGLE_CSE_ID=

# ─────────────────────────────────────────────────────────────
# 4. EMBEDDINGS
# ─────────────────────────────────────────────────────────────
# "local" uses @huggingface/transformers in-process (no API key, runs on CPU)
# Alternatives: openai, gemini, voyage, jina, ollama

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─────────────────────────────────────────────────────────────
# 5. LLM — AI Ranking & Research
# ─────────────────────────────────────────────────────────────
# Uses OPENCODE_API_KEY above. Base URL defaults to OpenCode Zen gateway.

LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL=big-pickle
LLM_PLANNER_MODEL=big-pickle
LLM_RESEARCH_MODEL=big-pickle

# ─────────────────────────────────────────────────────────────
# 6. RATE LIMITING
# ─────────────────────────────────────────────────────────────

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# ─────────────────────────────────────────────────────────────
# 7. SEARCH ENGINE TUNING
# ─────────────────────────────────────────────────────────────

SEARCH_TIMEOUT_MS=8000
EXTRACTION_TIMEOUT_MS=10000
MAX_PROVIDERS_PER_QUERY=6

# ─────────────────────────────────────────────────────────────
# 8. CRAWLER
# ─────────────────────────────────────────────────────────────

CRAWLER_JS_RENDER=false
CRAWLER_WEBHOOK_URL=
