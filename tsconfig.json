{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": false,
    "allowJs": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "sdk/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "sdk/dist"]
}
