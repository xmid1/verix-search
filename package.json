{
  "name": "verix-search",
  "version": "1.0.0",
  "description": "Verix — AI-Native Search & Research Platform for AI Agents",
  "private": true,
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx scripts/seed.ts",
    "benchmark": "tsx src/evaluation/index.ts",
    "benchmark:full": "tsx src/evaluation/index.ts --fail-on-threshold",
    "benchmark:quick": "tsx src/evaluation/index.ts --queries=research-swe-agent,research-re-act-reflexion,prog-ts-generics,prog-rust-ownership,academic-attention-mechanism,comparison-bun-deno-node",
    "benchmark:report": "tsx src/evaluation/index.ts --no-html",
    "quality:gate": "tsx src/evaluation/index.ts --fail-on-threshold",
    "quality:adversarial": "tsx src/evaluation/index.ts --queries=edge-empty,edge-minimal,edge-unicode-max,extreme-1000-results,malformed-sql-injection,security-api-key-in-query",
    "benchmark:mock": "tsx src/evaluation/index.ts --mock --no-html"
  },
  "keywords": [
    "search",
    "ai-agents",
    "research",
    "rag"
  ],
  "author": "XMidleg",
  "license": "MIT",
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.8.0",
    "@fastify/websocket": "^11.3.0",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/fastify-api-reference": "^1.62.5",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "bullmq": "^5.80.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "fast-xml-parser": "^5.10.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "ioredis": "^5.11.1",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.16",
    "openai": "^6.46.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "turndown": "^7.2.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  }
}
